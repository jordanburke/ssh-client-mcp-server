{
  "name": "ssh-client-mcp-server",
  "license": "MIT",
  "version": "1.3.0",
  "description": "MCP server that exposes SSH command execution to LLMs. Built on SomaMCP with functional config parsing (functype), path expansion (~, $VAR), and OS-user fallback.",
  "author": "Jordan Burke <jordan.burke@gmail.com>",
  "homepage": "https://github.com/jordanburke/ssh-client-mcp-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jordanburke/ssh-client-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/jordanburke/ssh-client-mcp-server/issues"
  },
  "keywords": [
    "mcp",
    "ssh",
    "ssh2",
    "model-context-protocol",
    "claude",
    "anthropic",
    "llm",
    "remote-shell",
    "somamcp",
    "fastmcp",
    "functype",
    "typescript",
    "cli"
  ],
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "ssh-client-mcp-server": "dist/index.js"
  },
  "files": [
    "lib",
    "dist"
  ],
  "scripts": {
    "validate": "ts-builds validate",
    "format": "ts-builds format",
    "format:check": "ts-builds format:check",
    "lint": "ts-builds lint",
    "lint:check": "ts-builds lint:check",
    "typecheck": "ts-builds typecheck",
    "test": "ts-builds test",
    "test:watch": "ts-builds test:watch",
    "test:coverage": "ts-builds test:coverage",
    "test:ui": "ts-builds test:ui",
    "build": "ts-builds build",
    "dev": "ts-builds dev",
    "inspect": "pnpm build && npx @modelcontextprotocol/inspector dist/index.js",
    "prepublishOnly": "pnpm validate"
  },
  "prettier": "ts-builds/prettier",
  "dependencies": {
    "functype": "^0.60.3",
    "functype-os": "^0.60.0",
    "somamcp": "^1.0.6",
    "ssh2": "^1.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ssh2": "^1.15.5",
    "ts-builds": "^2.7.2",
    "tsdown": "^0.21.10"
  },
  "packageManager": "pnpm@10.33.3+sha512.a19744364a7e248b92657a4ca5973f9354d21caf982579674b1c539f32c7420c47138ad8b1254df07aba9bc782d9b3029e3db34d5dbff974326eb74dac8ff489"
}
